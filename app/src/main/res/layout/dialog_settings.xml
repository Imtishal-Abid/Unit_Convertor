<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:paddingStart="24dp"
    android:paddingEnd="24dp"
    android:paddingTop="12dp"
    android:paddingBottom="24dp">

    <!-- Drag Handle at the top of the Bottom Sheet -->
    <View
        android:layout_width="48dp"
        android:layout_height="5dp"
        android:layout_gravity="center_horizontal"
        android:layout_marginBottom="18dp"
        android:background="@color/bento_border"
        android:backgroundTint="@color/bento_border" />

    <!-- Top Header: Title & Close Button -->
    <RelativeLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp">

        <TextView
            android:id="@+id/dialog_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentStart="true"
            android:layout_centerVertical="true"
            android:text="Settings"
            android:textColor="@color/bento_primary"
            android:textSize="22sp"
            android:textStyle="bold" />

        <!-- Small Close '✕' Icon Button in the Corner -->
        <FrameLayout
            android:id="@+id/btn_close_settings_icon"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:layout_alignParentEnd="true"
            android:layout_centerVertical="true"
            android:background="@drawable/bg_button_swap"
            android:backgroundTint="@color/bento_secondary_container"
            android:clickable="true"
            android:focusable="true">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="✕"
                android:textColor="@color/bento_on_primary_container"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>
    </RelativeLayout>

    <!-- Theme Section Header with Icon (Palette 🎨) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_palette"
            android:layout_marginEnd="8dp"
            android:contentDescription="Theme Mode Icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THEME MODE"
                android:textColor="@color/bento_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Choose your preferred appearance"
                android:textColor="@color/bento_text_muted"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Theme Selection Group -->
    <RadioGroup
        android:id="@+id/theme_radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">

        <RadioButton
            android:id="@+id/radio_system"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:text="   System Default"
            android:textColor="@color/theme_text_selector"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:buttonTint="@color/bento_primary"
            android:background="@drawable/bg_settings_option" />

        <RadioButton
            android:id="@+id/radio_light"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:layout_marginBottom="8dp"
            android:text="   Light Theme"
            android:textColor="@color/theme_text_selector"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:buttonTint="@color/bento_primary"
            android:background="@drawable/bg_settings_option" />

        <RadioButton
            android:id="@+id/radio_dark"
            android:layout_width="match_parent"
            android:layout_height="46dp"
            android:text="   Dark Theme"
            android:textColor="@color/theme_text_selector"
            android:textSize="14sp"
            android:textStyle="bold"
            android:paddingStart="8dp"
            android:paddingEnd="8dp"
            android:buttonTint="@color/bento_primary"
            android:background="@drawable/bg_settings_option" />
    </RadioGroup>

    <!-- Extra spacing between sections instead of a plain line divider -->
    <Space
        android:layout_width="match_parent"
        android:layout_height="28dp" />

    <!-- History Section Title with Icon (History 📜) -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:layout_marginBottom="12dp">

        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_history"
            android:layout_marginEnd="8dp"
            android:contentDescription="History Management Icon" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="HISTORY MANAGEMENT"
                android:textColor="@color/bento_text_muted"
                android:textSize="11sp"
                android:textStyle="bold"
                android:letterSpacing="0.08" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Manage your recent conversion entries"
                android:textColor="@color/bento_text_muted"
                android:textSize="11sp"
                android:layout_marginTop="2dp" />
        </LinearLayout>
    </LinearLayout>

    <!-- Clear History Button styled in a WARNING Red (Destructive) tone with Delete Icon -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btn_clear_history"
        style="@style/Widget.Material3.Button.TonalButton"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:text="Clear History"
        android:textColor="#BA1A1A"
        app:backgroundTint="#FFDAD9"
        app:strokeColor="#BA1A1A"
        app:strokeWidth="1dp"
        app:cornerRadius="12dp"
        app:icon="@drawable/ic_delete"
        app:iconTint="#BA1A1A"
        app:iconGravity="textStart"
        app:iconPadding="8dp" />

</LinearLayout>
